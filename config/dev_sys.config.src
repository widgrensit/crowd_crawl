[
    {kernel, [
        {logger_level, debug},
        {logger, [
            {handler, default, logger_std_h, #{
                formatter => {nova_jsonlogger, #{
                    map_depth => 3,
                    term_depth => 50
                }}
            }},
            {filters, log, [
                {progress, {fun logger_filters:progress/2, stop}}
            ]}
        ]}
    ]},
    {nova, [
        {use_stacktrace, true},
        {environment, dev},
        {cowboy_configuration, #{
            port => 8083
        }},
        {dev_mode, true},
        {bootstrap_application, crowd_crawl},
        {json_lib, json}
    ]},
    {kura, [
        {repo, asobi_repo},
        {host, "localhost"},
        {port, 5432},
        {database, "asobi_dev"},
        {user, "postgres"},
        {password, "postgres"},
        {pool_size, 50}
    ]},
    {asobi, [
        {nova_apps, []},
        {game_modes, #{
            ~"crowd_crawl" => crowd_crawl_game
        }},
        {vote_templates, #{
            ~"boon_pick" => #{method => ~"plurality", window_ms => 15000, visibility => ~"live"},
            ~"path_choice" => #{method => ~"approval", window_ms => 20000, visibility => ~"live"},
            ~"buff_nerf" => #{method => ~"weighted", window_ms => 15000, visibility => ~"live"},
            ~"boss_modifier" => #{method => ~"ranked", window_ms => 25000, visibility => ~"hidden"},
            ~"mercy_vote" => #{method => ~"plurality", window_ms => 20000, visibility => ~"live",
                              require_supermajority => true, supermajority => 0.75}
        }},
        {matchmaker, #{
            tick_interval => 1000,
            max_wait_seconds => 60
        }},
        {session, #{
            token_ttl => 900,
            refresh_ttl => 2592000
        }},
        {rate_limits, #{
            auth => #{limit => 300, window => 1000},
            api => #{limit => 300, window => 1000}
        }}
    ]},
    {pg, [{scope, [nova_scope]}]}
].
